diff --git a/src/app/features/medpath-landing/medpath-landing.component.css b/src/app/features/medpath-landing/medpath-landing.component.css
new file mode 100644
index 0000000..9194a20
--- /dev/null
+++ b/src/app/features/medpath-landing/medpath-landing.component.css
@@ -0,0 +1,224 @@
+/* ============================================================
+   MedPath Diagnostics — Landing Page (modular, standalone)
+   Uses global design tokens from src/styles.css (--card-bg,
+   --border-color, --text-primary, --text-secondary, --body-bg,
+   --font-family, --primary, --primary-dark, --accent-light) so the
+   page automatically follows whichever theme palette is active.
+   Component-local aliases below give this page its own brand-green
+   identity while still tracking the active theme.
+   ============================================================ */
+
+:host {
+  display: block;
+  font-family: var(--font-family, 'DM Sans', sans-serif);
+  background: var(--card-bg);
+
+  /* Local aliases — fall back to the mock's brand green if the
+     active theme doesn't define --primary / --primary-dark. */
+  --mp-brand:        var(--primary, #1D9E75);
+  --mp-brand-dark:   var(--primary-dark, #0F6E56);
+  --mp-brand-deep:   #04342C;
+  --mp-brand-tint:   var(--accent-light, #E1F5EE);
+  --mp-brand-tint-2: #D8F2E8;
+  --mp-brand-border: #9FE1CB;
+}
+
+/* Nav */
+.mp-nav { display:flex; align-items:center; padding:0 28px; height:56px; background:var(--card-bg); border-bottom:0.5px solid var(--border-color); position:sticky; top:0; z-index:100; }
+.mp-nav-brand { display:flex; align-items:center; gap:9px; }
+.mp-brand-icon { width:34px; height:34px; background:var(--mp-brand); border-radius:9px; display:flex; align-items:center; justify-content:center; i { color:#fff; font-size:18px; } }
+.mp-brand-name { font-size:13px; font-weight:500; color:var(--text-primary); line-height:1.2; }
+.mp-brand-tag  { font-size:10px; color:var(--text-secondary); }
+.mp-nav-links  { display:flex; align-items:center; gap:0; margin:0 auto; }
+.mp-link { padding:0 14px; font-size:13px; color:var(--text-secondary); cursor:pointer; height:56px; display:flex; align-items:center; border-bottom:2px solid transparent; text-decoration:none; }
+.mp-link--active { color:var(--mp-brand); border-bottom-color:var(--mp-brand); font-weight:500; }
+.mp-link:hover { color:var(--text-primary); }
+.mp-nav-cta { display:flex; align-items:center; gap:8px; }
+.mp-btn-outline { padding:6px 14px; border:1.5px solid var(--mp-brand); border-radius:8px; font-size:12px; color:var(--mp-brand); cursor:pointer; background:transparent; font-weight:500; font-family:inherit; }
+.mp-btn-solid  { padding:6px 14px; border:1.5px solid var(--mp-brand); border-radius:8px; font-size:12px; color:#fff; cursor:pointer; background:var(--mp-brand); font-weight:500; display:inline-flex; align-items:center; gap:5px; font-family:inherit; i { font-size:13px; } }
+.mp-btn-ghost  { padding:8px 18px; background:transparent; color:var(--mp-brand-dark); border:1.5px solid #5DCAA5; border-radius:9px; font-size:13px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:6px; font-family:inherit; i { font-size:14px; } }
+
+/* ============================================================
+   Hero
+   ============================================================ */
+.mp-hero { display:grid; grid-template-columns:1fr 380px; min-height:320px; background:#F0FAF6; }
+@media (max-width:900px) { .mp-hero { grid-template-columns:1fr; } }
+.mp-hero-left { padding:36px 32px 32px; display:flex; flex-direction:column; justify-content:center; }
+.mp-eyebrow { display:inline-flex; align-items:center; gap:6px; font-size:11px; color:var(--mp-brand-dark); font-weight:500; background:var(--mp-brand-tint-2); padding:4px 10px; border-radius:20px; margin-bottom:12px; width:fit-content; i { font-size:12px; } }
+.mp-h1  { font-size:28px; font-weight:500; color:#04342C; line-height:1.25; margin:0 0 10px; }
+.mp-sub { font-size:13px; color:var(--mp-brand-dark); line-height:1.6; margin:0 0 18px; max-width:360px; }
+.mp-trust { display:flex; gap:18px; margin-bottom:22px; flex-wrap:wrap; }
+.mp-trust-item { display:flex; align-items:center; gap:6px; font-size:12px; color:#085041; i { font-size:14px; color:var(--mp-brand); } }
+.mp-hero-btns { display:flex; gap:10px; flex-wrap:wrap; }
+
+/* ── Visual panel: soft blurred medical laboratory backdrop ── */
+.mp-hero-right {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: var(--mp-brand-tint);
+  padding: 24px;
+  position: relative;
+  overflow: hidden;
+  isolation: isolate; /* new stacking context so blurred layers never bleed over the card */
+}
+
+/* Layer 1 — the illustration itself, heavily blurred + low opacity.
+   Scaled up slightly so the blur radius doesn't reveal hard edges. */
+.mp-lab-bg {
+  position: absolute;
+  inset: -12%;
+  z-index: 0;
+  pointer-events: none;
+}
+.mp-lab-svg {
+  width: 100%;
+  height: 100%;
+  display: block;
+  filter: blur(26px) saturate(1.05);
+  opacity: 0.4;
+  transform: scale(1.15);
+}
+
+/* Layer 2 — a soft colour wash on top of the blurred art. This is what
+   keeps the login card the clear focal point: it lifts contrast right
+   behind the card without needing a heavier / darker blur underneath. */
+.mp-lab-wash {
+  position: absolute;
+  inset: 0;
+  z-index: 1;
+  pointer-events: none;
+  background: linear-gradient(
+    165deg,
+    rgba(240, 250, 246, 0.88) 0%,
+    rgba(225, 245, 238, 0.5) 45%,
+    rgba(240, 250, 246, 0.92) 100%
+  );
+}
+
+/* Layer 3 — small decorative dot-grid accent (bottom-left), matching
+   the reference design's premium-healthcare finishing touch. */
+.mp-dot-grid {
+  position: absolute;
+  left: -22px;
+  bottom: -22px;
+  width: 150px;
+  height: 150px;
+  z-index: 1;
+  pointer-events: none;
+  background-image: radial-gradient(var(--mp-brand) 1.6px, transparent 1.6px);
+  background-size: 14px 14px;
+  opacity: 0.18;
+}
+
+/* Respect reduced-motion / reduced-transparency preferences by
+   flattening the backdrop to a plain tint instead of a blurred photo. */
+@media (prefers-reduced-motion: reduce), (prefers-contrast: more) {
+  .mp-lab-svg { display: none; }
+  .mp-lab-wash { background: var(--mp-brand-tint); opacity: 1; }
+}
+
+/* Login card — sits above every backdrop layer, fully sharp/opaque. */
+.mp-login-card {
+  position: relative;
+  z-index: 2;
+  background: var(--card-bg);
+  border: 0.5px solid var(--mp-brand-border);
+  border-radius: 14px;
+  padding: 22px;
+  width: 100%;
+  max-width: 295px;
+  box-shadow: 0 4px 24px rgba(29, 158, 117, 0.08), 0 1px 3px rgba(4, 52, 44, 0.06);
+}
+.mp-lc-head   { text-align:center; margin-bottom:18px; }
+.mp-lc-icon   { width:42px; height:42px; background:var(--mp-brand-tint); border-radius:11px; display:flex; align-items:center; justify-content:center; margin:0 auto 9px; i { color:var(--mp-brand); font-size:21px; } }
+.mp-lc-title  { font-size:14px; font-weight:500; color:var(--text-primary); }
+.mp-lc-sub    { font-size:11px; color:var(--text-secondary); margin-top:2px; }
+.mp-err-box   { background:#FCEBEB; border-radius:7px; padding:8px 10px; font-size:11px; color:#791F1F; display:flex; align-items:center; gap:6px; margin-bottom:12px; i { font-size:14px; } }
+.mp-field     { display:flex; flex-direction:column; gap:4px; margin-bottom:10px; label { font-size:11px; color:var(--text-secondary); font-weight:500; } input { height:34px; border:0.5px solid var(--border-color); border-radius:8px; padding:0 10px; font-size:12px; color:var(--text-primary); background:var(--card-bg); outline:none; width:100%; font-family:inherit; &:focus { border-color:var(--mp-brand); } } }
+.mp-pw-wrap   { position:relative; display:flex; align-items:center; input { flex:1; padding-right:34px; } }
+.mp-pw-eye    { position:absolute; right:9px; background:none; border:none; cursor:pointer; color:var(--text-secondary); font-size:15px; }
+.mp-remember-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:13px; }
+.mp-check { display:flex; align-items:center; gap:5px; font-size:11px; color:var(--text-secondary); cursor:pointer; input { width:auto; height:auto; margin:0; } }
+.mp-forgot { font-size:11px; color:var(--mp-brand); text-decoration:none; }
+.mp-signin-btn { width:100%; padding:9px; background:var(--mp-brand); color:#fff; border:none; border-radius:9px; font-size:13px; font-weight:500; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px; font-family:inherit; &:hover { filter:brightness(1.07); } i { font-size:14px; } }
+.mp-secure-row { display:flex; align-items:center; justify-content:center; gap:5px; margin-top:10px; font-size:10px; color:#085041; i { font-size:12px; } }
+.mp-demo-hint { display:flex; align-items:center; justify-content:center; gap:5px; margin-top:6px; font-size:10px; color:var(--mp-brand-dark); background:rgba(29,158,117,0.08); border:0.5px solid rgba(29,158,117,0.25); border-radius:6px; padding:5px 10px; code { font-family:monospace; font-size:10px; background:rgba(29,158,117,0.12); padding:0 4px; border-radius:3px; } i { font-size:11px; flex-shrink:0; } }
+
+/* ============================================================
+   Sections
+   ============================================================ */
+.mp-section    { padding:34px 28px; }
+.mp-section--alt { background:var(--body-bg); }
+.mp-section-title { text-align:center; font-size:18px; font-weight:500; color:var(--text-primary); margin-bottom:5px; }
+.mp-section-sub   { text-align:center; font-size:12px; color:var(--text-secondary); margin-bottom:22px; }
+
+/* Test categories */
+.mp-cat-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:10px; }
+@media (max-width:1100px) { .mp-cat-grid { grid-template-columns:repeat(3,1fr); } }
+@media (max-width:600px)  { .mp-cat-grid { grid-template-columns:repeat(2,1fr); } }
+.mp-cat-card { background:var(--card-bg); border:0.5px solid var(--border-color); border-radius:10px; padding:14px 10px; text-align:center; cursor:pointer; transition:border-color 0.15s; &:hover { border-color:#5DCAA5; } }
+.mp-cat-icon { width:38px; height:38px; background:var(--mp-brand-tint); border-radius:9px; display:flex; align-items:center; justify-content:center; margin:0 auto 9px; i { font-size:19px; color:var(--mp-brand); } }
+.mp-cat-name { font-size:12px; font-weight:500; color:var(--text-primary); margin-bottom:3px; }
+.mp-cat-desc { font-size:10px; color:var(--text-secondary); line-height:1.4; }
+
+/* Stats band */
+.mp-stats-band { background:var(--mp-brand-deep); padding:20px 28px; display:grid; grid-template-columns:repeat(4,1fr); gap:0; }
+@media (max-width:700px) { .mp-stats-band { grid-template-columns:repeat(2,1fr); gap:12px; } }
+.mp-stat { text-align:center; padding:0 14px; border-right:1px solid rgba(255,255,255,0.12); &:last-child { border-right:none; } }
+.mp-stat-val { font-size:20px; font-weight:500; color:#fff; }
+.mp-stat-lbl { font-size:11px; color:#9FE1CB; margin-top:3px; }
+
+/* Why choose */
+.mp-why-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
+@media (max-width:900px) { .mp-why-grid { grid-template-columns:repeat(2,1fr); } }
+.mp-why-card { background:var(--body-bg); border-radius:10px; padding:15px; display:flex; flex-direction:column; gap:7px; }
+.mp-why-icon { width:35px; height:35px; background:var(--mp-brand-tint); border-radius:9px; display:flex; align-items:center; justify-content:center; i { font-size:18px; color:var(--mp-brand); } }
+.mp-why-title { font-size:13px; font-weight:500; color:var(--text-primary); }
+.mp-why-desc  { font-size:11px; color:var(--text-secondary); line-height:1.5; }
+
+/* CTA band */
+.mp-cta-band { background:var(--mp-brand); padding:22px 28px; display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
+.mp-cta-icon { width:46px; height:46px; background:rgba(255,255,255,0.15); border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; i { font-size:21px; color:#fff; } }
+.mp-cta-title { font-size:14px; font-weight:500; color:#fff; flex:1; }
+.mp-cta-sub   { font-size:12px; color:#9FE1CB; margin-top:2px; }
+.mp-cta-btn   { padding:8px 18px; background:#fff; color:#085041; border:none; border-radius:9px; font-size:12px; font-weight:500; cursor:pointer; white-space:nowrap; display:flex; align-items:center; gap:5px; font-family:inherit; i { font-size:13px; } }
+
+/* Footer */
+.mp-footer { background:#04342C; padding:26px 28px 14px; }
+.mp-footer-grid { display:grid; grid-template-columns:1.6fr 1fr 1fr 1.2fr 1.1fr; gap:20px; margin-bottom:20px; }
+@media (max-width:900px) { .mp-footer-grid { grid-template-columns:repeat(2,1fr); } }
+.mp-footer-name  { font-size:13px; font-weight:500; color:#fff; margin-bottom:3px; }
+.mp-footer-tag   { font-size:11px; color:#5DCAA5; margin-bottom:10px; }
+.mp-footer-socials { display:flex; gap:7px; }
+.mp-social-btn { width:27px; height:27px; border-radius:6px; background:rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; cursor:pointer; i { font-size:13px; color:#9FE1CB; } }
+.mp-fc-title { font-size:12px; font-weight:500; color:#fff; margin-bottom:9px; }
+.mp-fc-link  { display:block; font-size:11px; color:#9FE1CB; margin-bottom:5px; text-decoration:none; &:hover { color:#fff; } }
+.mp-fc-contact { display:flex; align-items:flex-start; gap:6px; font-size:11px; color:#9FE1CB; margin-bottom:6px; line-height:1.4; i { font-size:12px; flex-shrink:0; margin-top:1px; color:#5DCAA5; } }
+.mp-open-badge { display:inline-flex; align-items:center; gap:5px; background:rgba(29,158,117,0.2); padding:3px 9px; border-radius:20px; font-size:11px; color:#9FE1CB; margin-top:8px; }
+.mp-open-dot { width:7px; height:7px; border-radius:50%; background:#5DCAA5; }
+.mp-footer-bottom { border-top:1px solid rgba(255,255,255,0.08); padding-top:12px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; font-size:11px; color:#5DCAA5; }
+.mp-footer-policy { display:flex; gap:14px; a { font-size:11px; color:#5DCAA5; text-decoration:none; &:hover { color:#fff; } } }
+
+/* Mobile hamburger & drawer */
+.mp-hamburger { display:none; background:none; border:none; font-size:20px; color:var(--text-primary); cursor:pointer; padding:6px; margin-left:auto; }
+@media (max-width:768px) {
+  .mp-nav-links, .mp-nav-cta { display:none; }
+  .mp-hamburger { display:flex; align-items:center; }
+}
+.mp-mobile-menu {
+  position:fixed; top:56px; left:0; right:0; z-index:200;
+  background:var(--card-bg); border-bottom:1px solid var(--border-color);
+  display:flex; flex-direction:column; padding:12px 20px 16px; gap:0;
+  box-shadow:0 8px 24px rgba(0,0,0,0.12);
+}
+.mp-mob-link { padding:13px 0; font-size:14px; color:var(--text-primary); text-decoration:none; border-bottom:0.5px solid var(--border-color); }
+.mp-mob-cta  { margin-top:14px; justify-content:center; width:100%; }
+
+@media (max-width:600px) {
+  .mp-stats-band { display:grid; grid-template-columns:1fr 1fr; gap:0; flex-wrap:wrap; }
+  .mp-stat { padding:16px; }
+}
+
+/* Display font for landing page headings only */
+h1, h2 { font-family: 'Instrument Serif', Georgia, serif; }
diff --git a/src/app/features/medpath-landing/medpath-landing.component.html b/src/app/features/medpath-landing/medpath-landing.component.html
new file mode 100644
index 0000000..cf21be7
--- /dev/null
+++ b/src/app/features/medpath-landing/medpath-landing.component.html
@@ -0,0 +1,300 @@
+<!-- ============================================================
+     MedPath Diagnostics — Landing Page (modular, standalone)
+     ============================================================ -->
+
+<!-- Navbar -->
+<nav class="mp-nav" role="navigation" aria-label="Site navigation">
+  <div class="mp-nav-brand">
+    <div class="mp-brand-icon" aria-hidden="true"><i class="ti ti-flask"></i></div>
+    <div>
+      <div class="mp-brand-name">MedPath Diagnostics</div>
+      <div class="mp-brand-tag">Accurate Results. Better Health.</div>
+    </div>
+  </div>
+  <div class="mp-nav-links" role="list">
+    <a class="mp-link mp-link--active" href="#hero" role="listitem">Home</a>
+    <a class="mp-link" href="#about" role="listitem">About us</a>
+    <a class="mp-link" href="#tests" role="listitem">Tests</a>
+    <a class="mp-link" href="#why" role="listitem">Our process</a>
+    <a class="mp-link" href="#footer" role="listitem">Contact us</a>
+  </div>
+  <div class="mp-nav-cta">
+    <button class="mp-btn-outline" type="button" (click)="scrollToLogin()">View reports</button>
+    <button class="mp-btn-solid" type="button" (click)="scrollToLogin()">
+      <i class="ti ti-calendar" aria-hidden="true"></i> Book a test
+    </button>
+  </div>
+  <!-- Mobile hamburger -->
+  <button class="mp-hamburger" type="button"
+    (click)="mobileMenuOpen.set(!mobileMenuOpen())"
+    [attr.aria-expanded]="mobileMenuOpen()"
+    aria-label="Toggle navigation menu"
+    aria-controls="mp-mobile-menu">
+    <i [class]="mobileMenuOpen() ? 'ti ti-x' : 'ti ti-menu-2'" aria-hidden="true"></i>
+  </button>
+</nav>
+
+<!-- Mobile drawer -->
+@if (mobileMenuOpen()) {
+  <div class="mp-mobile-menu" id="mp-mobile-menu" role="dialog" aria-label="Mobile navigation">
+    <a class="mp-mob-link" href="#hero" (click)="mobileMenuOpen.set(false)">Home</a>
+    <a class="mp-mob-link" href="#about" (click)="mobileMenuOpen.set(false)">About us</a>
+    <a class="mp-mob-link" href="#tests" (click)="mobileMenuOpen.set(false)">Tests</a>
+    <a class="mp-mob-link" href="#why" (click)="mobileMenuOpen.set(false)">Our process</a>
+    <a class="mp-mob-link" href="#footer" (click)="mobileMenuOpen.set(false)">Contact us</a>
+    <button class="mp-btn-solid mp-mob-cta" type="button" (click)="scrollToLogin(); mobileMenuOpen.set(false)">
+      <i class="ti ti-calendar" aria-hidden="true"></i> Book a test
+    </button>
+  </div>
+}
+
+<!-- Hero -->
+<section class="mp-hero" id="hero" aria-label="Lab introduction">
+  <div class="mp-hero-left">
+    <div class="mp-eyebrow">
+      <i class="ti ti-certificate" aria-hidden="true"></i> NABL Accredited Laboratory
+    </div>
+    <h1 class="mp-h1">Your health,<br />our priority.</h1>
+    <p class="mp-sub">
+      Advanced diagnostics with accurate results and personalised care you can trust —
+      all from a single, streamlined system.
+    </p>
+    <div class="mp-trust" aria-label="Key qualities">
+      <div class="mp-trust-item"><i class="ti ti-shield-check" aria-hidden="true"></i> Accurate results</div>
+      <div class="mp-trust-item"><i class="ti ti-clock" aria-hidden="true"></i> Timely reports</div>
+      <div class="mp-trust-item"><i class="ti ti-headset" aria-hidden="true"></i> Expert support</div>
+    </div>
+    <div class="mp-hero-btns">
+      <button class="mp-btn-solid" type="button" (click)="scrollToLogin()">
+        <i class="ti ti-calendar" aria-hidden="true"></i> Book a test
+      </button>
+      <button class="mp-btn-ghost" type="button">
+        <i class="ti ti-file-text" aria-hidden="true"></i> View reports
