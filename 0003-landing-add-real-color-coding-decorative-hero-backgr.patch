+            <circle cx="138" cy="140" r="10" fill="#0B7A5C"/>
+            <circle cx="166" cy="110" r="10" fill="#B5730E"/>
+            <circle cx="194" cy="155" r="10" fill="#A8323A"/>
+            <circle cx="222" cy="125" r="10" fill="#2E5FC9"/>
+            <circle cx="250" cy="145" r="10" fill="#6947C4"/>
+          </g>
+
+          <!-- Microscope silhouette, right side -->
+          <g filter="url(#lpBlurScope)" opacity="0.4">
+            <rect x="270" y="250" width="90" height="20" rx="8" fill="url(#lpScopeGrad)"/>
+            <rect x="300" y="150" width="20" height="105" rx="9" fill="url(#lpScopeGrad)"/>
+            <ellipse cx="310" cy="150" rx="34" ry="16" fill="url(#lpScopeGrad)"/>
+            <rect x="292" y="95" width="26" height="60" rx="12" fill="url(#lpScopeGrad)" transform="rotate(-18 305 125)"/>
+            <circle cx="288" cy="85" r="13" fill="url(#lpScopeGrad)"/>
+          </g>
+        </svg>
         <div class="lp-login-card" id="login-card" role="region" aria-label="Operator login">
