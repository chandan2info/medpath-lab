+          <defs>
+            <linearGradient id="lpBenchGrad" x1="0" y1="0" x2="0" y2="1">
+              <stop offset="0%"  stop-color="#FFFFFF" stop-opacity="0"/>
+              <stop offset="20%" stop-color="#FFFFFF" stop-opacity="0.9"/>
+              <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.95"/>
+            </linearGradient>
+            <linearGradient id="lpScopeGrad" x1="0" y1="0" x2="1" y2="1">
+              <stop offset="0%"  stop-color="#C4CCD8"/>
+              <stop offset="100%" stop-color="#8A93A3"/>
+            </linearGradient>
+            <filter id="lpBlurBench" x="-30%" y="-30%" width="160%" height="160%">
+              <feGaussianBlur stdDeviation="22"/>
+            </filter>
+            <filter id="lpBlurTubes" x="-50%" y="-50%" width="200%" height="200%">
+              <feGaussianBlur stdDeviation="10"/>
+            </filter>
+            <filter id="lpBlurScope" x="-50%" y="-50%" width="200%" height="200%">
+              <feGaussianBlur stdDeviation="13"/>
+            </filter>
+          </defs>
+
+          <!-- Clean white laboratory bench, blurred into the base -->
+          <rect x="-20" y="270" width="420" height="150" fill="url(#lpBenchGrad)" filter="url(#lpBlurBench)"/>
+
+          <!-- Test tubes with colored samples, center -->
+          <g filter="url(#lpBlurTubes)" opacity="0.55">
+            <rect x="130" y="150" width="16" height="130" rx="8" fill="#3DC9A8"/>
+            <rect x="158" y="120" width="16" height="160" rx="8" fill="#F5A623"/>
