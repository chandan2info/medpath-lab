+  --lis-sb-bg-brand:        #110E18;
+  --lis-sb-search-bg:       #201B2E;
+  --lis-sb-sep:             rgba(255,255,255,0.07);
+  --lis-sb-text:            rgba(205,190,225,0.72);
+  --lis-sb-text-hover:      rgba(244,240,255,0.97);
+  --lis-sb-text-active:     #ffffff;
