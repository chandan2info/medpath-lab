+  --lis-sb-active-bg:       rgba(139,92,246,0.16);
+  --lis-sb-active-border:   #8B5CF6;
+  --lis-sb-active-glow:     rgba(139,92,246,0.35);
+  --lis-sb-icon-idle:       rgba(190,170,215,0.50);
+  --lis-sb-icon-hover:      #E0AAFA;
+  --lis-sb-icon-active:     #8B5CF6;
+  --lis-sb-col-icon-bg:     rgba(255,255,255,0.05);
+  --lis-sb-col-icon-hover:  rgba(192,38,211,0.18);
+  --lis-sb-col-icon-active: rgba(139,92,246,0.18);
+}
+[data-palette="violet"]:not([data-theme="dark"]) {
+  --lis-sb-bg:              #FAF8FF;
+  --lis-sb-bg-brand:        #F1E8FF;
+  --lis-sb-search-bg:       #EFDEFF;
+  --lis-sb-sep:             rgba(192,38,211,0.14);
+  --lis-sb-text:            #6B5286;
+  --lis-sb-text-hover:      #2A1B3D;
+  --lis-sb-text-active:     #16131F;
+  --lis-sb-caption:         #B79BD1;
+  --lis-sb-hover-bg:        rgba(192,38,211,0.11);
+  --lis-sb-hover-border:    #C026D3;
+  --lis-sb-active-bg:       rgba(139,92,246,0.14);
+  --lis-sb-active-border:   #6D28D9;
+  --lis-sb-active-glow:     rgba(139,92,246,0.30);
+  --lis-sb-icon-idle:       #9377AD;
+  --lis-sb-icon-hover:      #C026D3;
+  --lis-sb-icon-active:     #6D28D9;
+  --lis-sb-col-icon-bg:     rgba(192,38,211,0.07);
+  --lis-sb-col-icon-hover:  rgba(192,38,211,0.16);
+  --lis-sb-col-icon-active: rgba(139,92,246,0.16);
+}
+
+/* ─── VIOLET — Dark ────────────────────────────────────────── */
+[data-theme="dark"][data-palette="violet"] {
+  --lis-primary:        #8B5CF6;
+  --lis-primary-mid:    #D8B4FE;
+  --lis-primary-light:  #2D2545;
+  --lis-primary-xlight: rgba(139,92,246,0.14);
+  --lis-primary-deep:   #EFDEFF;
+
+  --pill-pending-bg:    rgba(245,158,11,0.15);
+  --pill-pending-color: #fbbf57;
+  --pill-process-bg:    rgba(236,72,153,0.22);
+  --pill-process-color: #f9a8d4;
+  --pill-ready-bg:      rgba(139,92,246,0.18);
+  --pill-ready-color:   #D8B4FE;
+  --pill-critical-bg:   rgba(226,75,74,0.18);
+  --pill-critical-color:#f87171;
+  --pill-stat-bg:       #7f1d1d;
+  --pill-stat-color:    #fca5a5;
+
+  --topbar-bg:          var(--bg-surface);
+}
+
+/* ─── Form input focus ring — palette-aware ─────────────────
+   .field-input (used across patient registration, billing,
+   sample tracking forms) hardcodes a lavender ring in the
+   default theme — left untouched. New palettes get a ring
+   that matches their own primary color. ── */
+[data-palette="ocean"]   .field-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--lis-primary-xlight); }
+[data-palette="sunset"]  .field-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--lis-primary-xlight); }
+[data-palette="violet"]  .field-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--lis-primary-xlight); }
+
+
    ═══════════════════════════════════════════════════════════ */
 
 /* ── Shell ── */
