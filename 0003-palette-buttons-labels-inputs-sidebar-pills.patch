+  --lis-sb-col-icon-hover:  rgba(249,115,22,0.16);
+  --lis-sb-col-icon-active: rgba(251,113,133,0.16);
+}
+
+/* ─── SUNSET — Dark ────────────────────────────────────────── */
+[data-theme="dark"][data-palette="sunset"] {
+  --lis-primary:        #FB7185;
+  --lis-primary-mid:    #FDBA74;
+  --lis-primary-light:  #3A2924;
+  --lis-primary-xlight: rgba(251,113,133,0.14);
+  --lis-primary-deep:   #FFE9D5;
+
+  --pill-pending-bg:    rgba(245,158,11,0.15);
+  --pill-pending-color: #fbbf57;
+  --pill-process-bg:    rgba(251,113,133,0.22);
