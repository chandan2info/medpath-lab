+  --lis-sb-col-icon-hover:  rgba(37,99,235,0.16);
+  --lis-sb-col-icon-active: rgba(14,165,233,0.16);
+}
+
+/* ─── OCEAN — Dark ─────────────────────────────────────────── */
+[data-theme="dark"][data-palette="ocean"] {
+  --lis-primary:        #0EA5E9;
+  --lis-primary-mid:    #7DD3FC;
+  --lis-primary-light:  #16314A;
+  --lis-primary-xlight: rgba(14,165,233,0.14);
+  --lis-primary-deep:   #DFF4FF;
+
+  --pill-pending-bg:    rgba(245,158,11,0.15);
+  --pill-pending-color: #fbbf57;
+  --pill-process-bg:    rgba(37,99,235,0.25);
+  --pill-process-color: #93C5FD;
+  --pill-ready-bg:      rgba(14,165,233,0.18);
+  --pill-ready-color:   #7DD3FC;
