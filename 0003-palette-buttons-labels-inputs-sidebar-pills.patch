+  --lis-sb-bg:              #FFF8F6;
+  --lis-sb-bg-brand:        #FFEFEC;
+  --lis-sb-search-bg:       #FFE9E4;
+  --lis-sb-sep:             rgba(249,115,22,0.14);
+  --lis-sb-text:            #7A5048;
+  --lis-sb-text-hover:      #3D211C;
+  --lis-sb-text-active:     #1C1412;
+  --lis-sb-caption:         #C2998D;
+  --lis-sb-hover-bg:        rgba(249,115,22,0.11);
+  --lis-sb-hover-border:    #F97316;
