From 2eaf2a183080f1b707b13f68739b437f2dcc0d57 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Tue, 30 Jun 2026 05:12:11 +0000
Subject: [PATCH] feat: palette-aware buttons, labels, inputs, sidebar & status
 pills
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Added [data-palette="ocean|sunset|violet"] overrides for the LIS module
  token set (--lis-primary*, --lis-sb-*, --pill-*, --topbar-bg) which drives
  buttons (.lis-btn), labels, sidebar hover/active states, and status pills
  across patient registration, billing, sample tracking, result entry
- Added palette-matched focus ring color for .field-input text boxes
  (previously hardcoded lavender for all themes)
- Default palette block (:root / [data-theme="dark"] with no [data-palette])
  is completely untouched — original Teal/Indigo colors unchanged
- Each palette covers both light and dark mode independently
---
 src/styles.css | 286 ++++++++++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 285 insertions(+), 1 deletion(-)

diff --git a/src/styles.css b/src/styles.css
index 292e37c..8c49778 100644
--- a/src/styles.css
+++ b/src/styles.css
@@ -4201,7 +4201,291 @@
 }
 
 /* ═══════════════════════════════════════════════════════════
-   EXPANDED SIDEBAR — Clinical Depth Design
+   PALETTE OVERRIDES — LIS tokens (buttons, labels, inputs,
+   sidebar, status pills) for the 3 new color palettes.
+   ─────────────────────────────────────────────────────────
+   The "default" palette (no [data-palette] attr) intentionally
+   has ZERO rules here — it keeps using the original :root /
+   [data-theme="dark"] LIS block above, completely unchanged.
+   ═══════════════════════════════════════════════════════════ */
