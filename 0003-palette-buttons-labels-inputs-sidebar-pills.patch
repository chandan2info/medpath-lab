+  --lis-sb-bg-brand:        #EAF4FF;
+  --lis-sb-search-bg:       #E3F1FF;
+  --lis-sb-sep:             rgba(37,99,235,0.14);
+  --lis-sb-text:            #3E5C7A;
+  --lis-sb-text-hover:      #14283D;
+  --lis-sb-text-active:     #0B1622;
+  --lis-sb-caption:         #8FA9C2;
+  --lis-sb-hover-bg:        rgba(37,99,235,0.11);
+  --lis-sb-hover-border:    #2563EB;
+  --lis-sb-active-bg:       rgba(14,165,233,0.14);
+  --lis-sb-active-border:   #0284C7;
+  --lis-sb-active-glow:     rgba(14,165,233,0.30);
