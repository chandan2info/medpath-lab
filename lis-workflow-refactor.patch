+/* ── Form wrapper — single column, max-width centered ── */
+.reg-form-wrap { max-width: 720px; display: flex; flex-direction: column; gap: 12px; }
+.reg-card { margin-bottom: 0; }
+
+/* ── Form grid ──────────────────────────────────────── */
+.form-grid {
+  display: grid; grid-template-columns: 1fr 1fr;
+  gap: 12px; padding: 14px 16px;
+}
+.form-full { grid-column: 1 / -1; }
+@media (max-width: 540px) { .form-grid { grid-template-columns: 1fr; } }
+.input-error { border-color: #E24B4A !important; }
+.err-msg  { font-size: 10px; color: #E24B4A; margin-top: 3px; display: block; }
+.req      { color: #E24B4A; }
+.opt-label { font-size: 10px; color: var(--text-secondary); font-weight: 400; }
+
+/* ── Patient recap (step 2) ─────────────────────────── */
+.patient-recap {
+  display: flex; align-items: center; gap: 10px;
+  padding: 10px 16px; border-bottom: 0.5px solid var(--border-color);
+  background: var(--lis-primary-xlight, #E1F5EE);
+}
+.recap-av {
+  width: 34px; height: 34px; border-radius: 50%;
+  background: var(--lis-primary, #1D9E75); color: #fff;
+  display: flex; align-items: center; justify-content: center;
+  font-size: 12px; font-weight: 600; flex-shrink: 0;
+  text-transform: uppercase;
+}
+.recap-info { flex: 1; min-width: 0; }
+.recap-name { font-size: 13px; font-weight: 500; color: var(--text-primary); }
+.recap-meta { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }
+.recap-edit { margin-left: auto; }
+
+/* ── Form actions bar ───────────────────────────────── */
+.form-actions {
+  display: flex; justify-content: flex-end; gap: 8px; padding-top: 4px;
+}
+.save-btn { min-width: 170px; justify-content: center; }
+.save-btn:disabled { opacity: 0.7; cursor: not-allowed; }
+
+/* ── Spinner ─────────────────────────────────────────── */
+@keyframes spin { to { transform: rotate(360deg); } }
+.spin { display: inline-block; animation: spin 0.8s linear infinite; }
+
+/* ═══════════════════════════════════════════════════════
+   SUCCESS OVERLAY
+   ═══════════════════════════════════════════════════════ */
+.success-overlay {
+  position: fixed; inset: 0; z-index: 9999;
+  background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(4px);
+  display: flex; align-items: center; justify-content: center;
+  animation: fadeIn 0.25s ease;
+}
+@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
+
+.success-card {
+  background: var(--card-bg); border-radius: 16px;
+  padding: 36px 40px; max-width: 400px; width: 92%;
+  text-align: center;
+  box-shadow: 0 24px 64px rgba(0,0,0,0.3);
+  animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
+}
+@keyframes slideUp { from { transform: translateY(24px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
+
+.success-icon {
+  font-size: 52px; color: var(--lis-primary, #1D9E75);
+  line-height: 1; margin-bottom: 12px;
+}
+.success-title {
+  font-size: 17px; font-weight: 600;
+  color: var(--text-primary); margin: 0 0 20px;
+}
+.success-pid-block {
+  background: var(--lis-primary-xlight, #E1F5EE);
+  border: 1px solid var(--lis-primary-mid, #5DCAA5);
+  border-radius: 10px; padding: 12px 20px; margin-bottom: 14px;
+}
+.success-pid-label {
+  font-size: 10px; text-transform: uppercase; letter-spacing: .07em;
+  color: var(--lis-primary-deep, #085041); font-weight: 500; margin-bottom: 4px;
+}
+.success-pid {
+  font-size: 22px; font-weight: 700;
+  color: var(--lis-primary-deep, #085041); letter-spacing: .05em;
+}
+.success-meta {
+  display: flex; align-items: center; justify-content: center; gap: 6px;
+  font-size: 12px; color: var(--text-secondary); margin-bottom: 16px;
+}
+.success-sep { color: var(--border-color); }
+.success-name { font-weight: 500; color: var(--text-primary); }
+.success-redirect {
+  font-size: 12px; color: var(--text-secondary); margin-bottom: 18px;
+  strong { color: var(--text-primary); }
+}
+.success-cta { width: 100%; justify-content: center; font-size: 13px; padding: 11px; margin-bottom: 8px; }
+.success-hint { font-size: 11px; color: var(--text-secondary); }
