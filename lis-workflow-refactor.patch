diff --git a/src/app/features/test-order/test-order.component.css b/src/app/features/test-order/test-order.component.css
new file mode 100644
index 0000000..e78248d
--- /dev/null
+++ b/src/app/features/test-order/test-order.component.css
@@ -0,0 +1,218 @@
+:host { display: block; }
+
+/* ── Page header ─────────────────────────────── */
+.page-header {
+  display: flex; align-items: flex-start;
+  justify-content: space-between; flex-wrap: wrap;
+  gap: 12px; margin-bottom: 14px;
+}
+.page-title { font-size: 20px; font-weight: 500; color: var(--text-primary); margin: 0 0 3px; }
+.breadcrumb { display: flex; list-style: none; padding: 0; margin: 0; gap: 6px; font-size: 12px; color: var(--text-secondary); }
+.breadcrumb li+li::before { content: '/'; margin-right: 6px; }
+.breadcrumb a { color: var(--text-secondary); text-decoration: none; &:hover { color: var(--lis-primary, #1D9E75); } }
+
+/* ── Workflow trail ───────────────────────────── */
+.workflow-trail {
+  display: flex; align-items: center; gap: 6px;
+  background: var(--body-bg); border: 0.5px solid var(--border-color);
+  border-radius: 9px; padding: 6px 12px;
+}
+.wf-step { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text-secondary); i { font-size: 13px; } }
+.wf-step--active { color: var(--lis-primary-deep, #085041); font-weight: 500; i { color: var(--lis-primary, #1D9E75); } }
+.wf-step--done   { color: var(--lis-primary, #1D9E75); font-weight: 500; }
+.wf-arrow { font-size: 11px; color: var(--border-color); }
+
+/* ── Patient banner ──────────────────────────── */
+.patient-banner {
+  display: flex; align-items: center; gap: 12px;
+  background: var(--lis-primary-xlight, #E1F5EE);
+  border: 0.5px solid var(--lis-primary-mid, #5DCAA5);
+  border-radius: 10px; padding: 10px 14px; margin-bottom: 14px;
+  flex-wrap: wrap;
+}
+.pat-av {
+  width: 38px; height: 38px; border-radius: 50%;
+  background: var(--lis-primary, #1D9E75); color: #fff;
+  display: flex; align-items: center; justify-content: center;
+  font-size: 13px; font-weight: 600; flex-shrink: 0; text-transform: uppercase;
+}
+.pat-main { flex: 1; min-width: 0; }
+.pat-name { font-size: 14px; font-weight: 500; color: var(--text-primary); }
+.pat-meta {
+  display: flex; flex-wrap: wrap; align-items: center;
+  gap: 5px; font-size: 11px; color: var(--text-secondary); margin-top: 3px;
+}
+.pid-tag { font-size: 11px; }
+.meta-sep { color: var(--border-color); }
+.visit-tag {
+  background: var(--card-bg); border: 0.5px solid var(--border-color);
+  border-radius: 20px; padding: 1px 7px; font-size: 10px;
+}
+
+/* ── Two-column layout ───────────────────────── */
+.order-layout {
+  display: grid;
+  grid-template-columns: 1fr 280px;
+  gap: 14px; align-items: start;
+}
+@media (max-width: 900px) { .order-layout { grid-template-columns: 1fr; } }
+
+/* ── Search column ───────────────────────────── */
+.search-col { display: flex; flex-direction: column; gap: 12px; }
+
+.search-card { overflow: hidden; }
+.search-bar-wrap {
+  display: flex; align-items: center; gap: 8px;
+  padding: 10px 14px; border-bottom: 0.5px solid var(--border-color);
+}
+.search-ico { font-size: 16px; color: var(--text-secondary); flex-shrink: 0; }
+.search-input {
+  flex: 1; background: transparent; border: none; outline: none;
+  font-size: 13px; color: var(--text-primary);
+  &::placeholder { color: var(--text-secondary); }
+}
+.search-clear {
+  background: none; border: none; cursor: pointer;
+  color: var(--text-secondary); font-size: 13px; padding: 2px;
+  &:hover { color: #E24B4A; }
+}
+.cat-pills { display: flex; gap: 5px; flex-wrap: wrap; padding: 8px 14px; }
+.cat-pill {
+  font-size: 11px; padding: 3px 10px; border-radius: 20px;
+  border: 0.5px solid var(--border-color); cursor: pointer;
+  color: var(--text-secondary); background: var(--card-bg);
+  &:hover { border-color: var(--lis-primary-mid, #5DCAA5); }
+}
+.cat-pill--active {
+  background: var(--lis-primary-xlight, #E1F5EE);
+  color: var(--lis-primary-deep, #085041);
+  border-color: var(--lis-primary-mid, #5DCAA5);
+}
+
+/* ── Popular tests ───────────────────────────── */
+.popular-card {}
+.popular-grid {
+  display: flex; flex-wrap: wrap; gap: 8px;
+  padding: 10px 14px 14px;
+}
+.popular-pill {
+  display: flex; align-items: center; gap: 6px;
+  padding: 7px 12px; border-radius: 8px;
+  border: 0.5px solid var(--border-color);
+  background: var(--body-bg); cursor: pointer;
+  position: relative;
+  &:hover { border-color: var(--lis-primary-mid, #5DCAA5); background: var(--lis-primary-xlight, #E1F5EE); }
+}
+.popular-pill--sel {
+  background: var(--lis-primary-xlight, #E1F5EE);
+  border-color: var(--lis-primary, #1D9E75);
+}
+.pp-name { font-size: 12px; font-weight: 600; color: var(--text-primary); }
+.pp-price { font-size: 10px; color: var(--text-secondary); }
+.pp-check { font-size: 11px; color: var(--lis-primary, #1D9E75); }
+
+/* ── Test catalogue list ─────────────────────── */
+.catalogue-card {}
+.test-list { display: flex; flex-direction: column; }
+.empty-tests {
+  display: flex; align-items: center; gap: 6px;
+  padding: 20px 14px; font-size: 12px; color: var(--text-secondary);
+  i { font-size: 18px; }
+}
+.test-row {
+  display: flex; align-items: center; gap: 10px;
+  padding: 10px 14px; cursor: pointer;
+  border-bottom: 0.5px solid var(--border-color);
+  transition: background 0.12s;
+  &:last-child { border-bottom: none; }
+  &:hover { background: var(--body-bg); }
+}
+.test-row--selected { background: var(--lis-primary-xlight, #E1F5EE); }
+.test-tog {
+  width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
+  border: 1.5px solid var(--border-color);
+  display: flex; align-items: center; justify-content: center;
+  font-size: 12px; color: var(--text-secondary);
+}
+.test-tog--on {
+  background: var(--lis-primary, #1D9E75);
+  border-color: var(--lis-primary, #1D9E75); color: #fff;
+}
+.test-info { flex: 1; min-width: 0; }
+.test-name { font-size: 13px; font-weight: 500; color: var(--text-primary); }
+.test-meta { font-size: 11px; color: var(--text-secondary); margin-top: 2px; display: flex; gap: 5px; }
+.test-cat  {}
+.test-dot  {}
+.test-price { font-size: 12px; font-weight: 500; color: var(--lis-primary-deep, #085041); min-width: 50px; text-align: right; }
+
+/* ── Order panel (right) ─────────────────────── */
+.order-panel {
+  position: sticky; top: 80px;
+  display: flex; flex-direction: column;
+}
+.op-section { padding: 12px 14px; }
+.op-hd {
+  display: flex; align-items: center; justify-content: space-between;
+  font-size: 11px; font-weight: 600; text-transform: uppercase;
+  letter-spacing: .05em; color: var(--text-secondary); margin-bottom: 8px;
+}
+.op-label {
+  font-size: 10px; font-weight: 600; text-transform: uppercase;
+  letter-spacing: .06em; color: var(--text-secondary); margin-bottom: 7px;
+}
+.op-divider { height: 0.5px; background: var(--border-color); margin: 0; }
+.op-actions { padding: 12px 14px; display: flex; flex-direction: column; gap: 6px; }
+
+/* Selected tests */
+.selected-list { display: flex; flex-direction: column; gap: 4px; min-height: 40px; }
+.no-tests-hint {
+  display: flex; align-items: center; gap: 6px;
+  font-size: 11px; color: var(--text-secondary); padding: 8px 0;
+  i { font-size: 16px; }
+}
+.sel-item {
+  display: flex; align-items: center; gap: 6px;
+  padding: 6px 8px; border-radius: 7px;
+  background: var(--body-bg); border: 0.5px solid var(--border-color);
+  animation: fadeIn 0.15s ease;
+}
+@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
+.sel-item-info { flex: 1; min-width: 0; }
+.sel-name  { font-size: 11px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
+.sel-cat   { font-size: 10px; color: var(--text-secondary); }
+.sel-price { font-size: 11px; font-weight: 500; color: var(--lis-primary-deep, #085041); min-width: 38px; text-align: right; }
+.sel-del   { background: none; border: none; cursor: pointer; color: var(--text-secondary); font-size: 12px; padding: 2px; &:hover { color: #E24B4A; } }
+
+/* Priority */
+.prio-row { display: flex; gap: 5px; }
+.prio-btn {
+  flex: 1; padding: 6px 4px; border: 0.5px solid var(--border-color);
+  border-radius: 7px; cursor: pointer; font-size: 11px;
+  color: var(--text-secondary); background: var(--card-bg); text-transform: capitalize;
+}
+.prio-btn--active { border-color: var(--lis-primary, #1D9E75); background: var(--lis-primary-xlight, #E1F5EE); color: var(--lis-primary-deep, #085041); font-weight: 500; }
+.prio-btn--stat   { border-color: #E24B4A; background: #FCEBEB; color: #791F1F; }
+.stat-warn {
+  display: flex; align-items: center; gap: 5px;
+  font-size: 10px; color: #791F1F; margin-top: 6px;
+  background: #FCEBEB; border-radius: 6px; padding: 5px 8px;
+}
+
+/* Totals */
+.tot-row {
+  display: flex; justify-content: space-between;
+  font-size: 11px; color: var(--text-secondary); padding: 3px 0;
+}
+.tot-grand {
+  font-size: 15px; font-weight: 600; color: var(--text-primary);
+  padding-top: 8px; border-top: 0.5px solid var(--border-color); margin-top: 4px;
+}
+
+/* Proceed button */
+.proceed-btn { font-size: 12px; }
+.proceed-btn:disabled { opacity: 0.55; cursor: not-allowed; }
+.no-tests-msg { font-size: 11px; color: var(--text-secondary); text-align: center; padding: 0 14px 12px; }
+
+/* Spinner */
+@keyframes spin { to { transform: rotate(360deg); } }
+.spin { display: inline-block; animation: spin 0.8s linear infinite; }
diff --git a/src/app/features/test-order/test-order.component.html b/src/app/features/test-order/test-order.component.html
new file mode 100644
index 0000000..f7cbb61
--- /dev/null
+++ b/src/app/features/test-order/test-order.component.html
@@ -0,0 +1,267 @@
+<!-- ═══════════════════════════════════════════════════════════
+     Screen 2 — Test Order
+     Full-width: search panel left, order panel right.
+     ═══════════════════════════════════════════════════════════ -->
+
+<!-- Page header -->
+<div class="page-header">
+  <div>
+    <h1 class="page-title">Test Order</h1>
+    <nav aria-label="Breadcrumb">
+      <ol class="breadcrumb">
+        <li><a routerLink="/dashboard/home">Home</a></li>
+        <li><a routerLink="/dashboard/registration">Registration</a></li>
+        <li aria-current="page">Test Order</li>
+      </ol>
+    </nav>
+  </div>
+  <div class="workflow-trail" aria-label="Workflow steps">
+    <div class="wf-step wf-step--done"><i class="ti ti-check"></i> Registered</div>
+    <i class="ti ti-chevron-right wf-arrow" aria-hidden="true"></i>
+    <div class="wf-step wf-step--active"><i class="ti ti-test-pipe"></i> Test Order</div>
+    <i class="ti ti-chevron-right wf-arrow" aria-hidden="true"></i>
+    <div class="wf-step"><i class="ti ti-file-invoice"></i> Billing</div>
+    <i class="ti ti-chevron-right wf-arrow" aria-hidden="true"></i>
+    <div class="wf-step"><i class="ti ti-droplet"></i> Sample</div>
+  </div>
+</div>
+
+<!-- Patient banner -->
+@if (patient) {
+  <div class="patient-banner" role="region" aria-label="Patient information">
+    <div class="pat-av" aria-hidden="true">{{ patientInitials }}</div>
+    <div class="pat-main">
+      <div class="pat-name">{{ patient.firstName }} {{ patient.lastName }}</div>
+      <div class="pat-meta">
+        <span class="lis-mono pid-tag">{{ patient.id }}</span>
+        <span class="meta-sep" aria-hidden="true">·</span>
+        <span>{{ patientAge }}</span>
+        <span class="meta-sep" aria-hidden="true">·</span>
+        <span>{{ patient.gender }}</span>
+        <span class="meta-sep" aria-hidden="true">·</span>
+        <span>{{ patient.mobile }}</span>
+        <span class="meta-sep" aria-hidden="true">·</span>
+        <span>{{ patient.refDoctor }}</span>
+        <span class="meta-sep" aria-hidden="true">·</span>
+        <span class="visit-tag">{{ patient.visitType }}</span>
+      </div>
+    </div>
+    <a routerLink="/dashboard/registration" class="lis-btn lis-btn--secondary lis-btn--sm" aria-label="Edit patient details">
+      <i class="ti ti-edit" aria-hidden="true"></i> Edit patient
+    </a>
+  </div>
+}
+
+<!-- Main layout: search left, order panel right -->
+<div class="order-layout">
+
+  <!-- ── Left: Test search catalogue ──────────── -->
+  <div class="search-col">
+
+    <!-- Search bar -->
+    <div class="lis-card search-card">
+      <div class="search-bar-wrap">
+        <i class="ti ti-search search-ico" aria-hidden="true"></i>
+        <input
+          type="search"
+          class="search-input"
+          placeholder="Search test by name or code…"
+          [value]="testQuery()"
+          (input)="testQuery.set($any($event.target).value)"
+          aria-label="Search tests"
+          autofocus />
+        @if (testQuery()) {
+          <button type="button" class="search-clear" (click)="clearSearch()" aria-label="Clear search">
+            <i class="ti ti-x" aria-hidden="true"></i>
+          </button>
+        }
+      </div>
+
+      <!-- Category pills -->
+      <div class="cat-pills" role="group" aria-label="Test categories">
+        @for (cat of flow.categories; track cat) {
+          <button type="button" class="cat-pill"
+            [class.cat-pill--active]="activeCategory() === cat"
+            (click)="activeCategory.set(cat)"
+            [attr.aria-pressed]="activeCategory() === cat">{{ cat }}</button>
+        }
+      </div>
+    </div>
+
+    <!-- Popular tests (shown when no query) -->
+    @if (!testQuery()) {
+      <div class="lis-card popular-card">
+        <div class="lis-card__header">
+          <i class="ti ti-star lis-card-icon" aria-hidden="true"></i>
+          <h2 class="lis-card__title">Popular Tests</h2>
+          <span class="lis-badge">Quick pick</span>
+        </div>
+        <div class="popular-grid" role="list" aria-label="Popular tests">
+          @for (t of flow.popularTests; track t.id) {
+            <button type="button" class="popular-pill"
+              [class.popular-pill--sel]="isSelected(t.id)"
+              (click)="toggle(t)"
+              role="listitem"
+              [attr.aria-pressed]="isSelected(t.id)"
+              [attr.aria-label]="t.name + ', ₹' + t.price">
+              <span class="pp-name">{{ t.id }}</span>
+              <span class="pp-price">₹{{ t.price }}</span>
+              @if (isSelected(t.id)) {
+                <i class="ti ti-check pp-check" aria-hidden="true"></i>
+              }
+            </button>
+          }
+        </div>
+      </div>
+    }
+
+    <!-- Test catalogue list -->
+    <div class="lis-card catalogue-card">
+      <div class="lis-card__header">
+        <i class="ti ti-list lis-card-icon" aria-hidden="true"></i>
+        <h2 class="lis-card__title">
+          {{ testQuery() ? 'Search results' : 'All Tests' }}
+        </h2>
+        <span class="lis-badge">{{ filteredTests().length }} tests</span>
+      </div>
+
+      <div class="test-list" role="list" aria-label="Test catalogue">
+        @if (filteredTests().length === 0) {
+          <div class="empty-tests" role="status">
+            <i class="ti ti-search-off" aria-hidden="true"></i>
+            No tests match "{{ testQuery() }}"
+          </div>
+        }
+        @for (t of filteredTests(); track t.id) {
+          <div class="test-row"
+            role="listitem"
+            [class.test-row--selected]="isSelected(t.id)"
+            (click)="toggle(t)"
+            [attr.aria-pressed]="isSelected(t.id)"
+            [attr.aria-label]="t.name + ', ' + t.category + ', ₹' + t.price + (isSelected(t.id) ? ', selected' : '')">
+            <div class="test-tog"
+              [class.test-tog--on]="isSelected(t.id)"
+              aria-hidden="true">
+              @if (isSelected(t.id)) {
+                <i class="ti ti-check"></i>
+              } @else {
+                <i class="ti ti-plus"></i>
+              }
+            </div>
+            <div class="test-info">
+              <div class="test-name">{{ t.name }}</div>
+              <div class="test-meta">
+                <span class="test-cat">{{ t.category }}</span>
+                <span class="test-dot" aria-hidden="true">·</span>
+                <span>{{ t.tatHours }}h TAT</span>
+              </div>
+            </div>
+            <div class="test-price">₹{{ t.price }}</div>
+          </div>
+        }
+      </div>
+    </div>
+  </div>
+
+  <!-- ── Right: Order panel ────────────────── -->
+  <aside class="order-panel lis-card" aria-label="Test order summary">
+
+    <!-- Selected tests -->
+    <div class="op-section">
+      <div class="op-hd">
+        <span>Selected Tests</span>
+        <span class="lis-badge">{{ flow.selectedTests().length }}</span>
+      </div>
+
+      <div class="selected-list" role="list" aria-label="Selected tests" aria-live="polite">
+        @if (flow.selectedTests().length === 0) {
+          <div class="no-tests-hint">
+            <i class="ti ti-click" aria-hidden="true"></i>
+            Click tests on the left to add them
+          </div>
+        }
+        @for (t of flow.selectedTests(); track t.id) {
+          <div class="sel-item" role="listitem">
+            <div class="sel-item-info">
+              <div class="sel-name">{{ t.name }}</div>
+              <div class="sel-cat">{{ t.category }}</div>
+            </div>
+            <div class="sel-price">₹{{ t.price }}</div>
+            <button type="button" class="sel-del"
+              (click)="toggle(t)"
+              [attr.aria-label]="'Remove ' + t.name">
+              <i class="ti ti-x" aria-hidden="true"></i>
+            </button>
+          </div>
+        }
+      </div>
+    </div>
+
+    <div class="op-divider" aria-hidden="true"></div>
+
+    <!-- Priority -->
+    <div class="op-section">
+      <div class="op-label">Priority</div>
+      <div class="prio-row" role="group" aria-label="Order priority">
+        @for (p of ['routine','urgent','stat']; track p) {
+          <button type="button" class="prio-btn"
+            [class.prio-btn--active]="flow.priority() === p"
+            [class.prio-btn--stat]="p === 'stat' && flow.priority() === 'stat'"
+            (click)="onPriorityClick(p)"
+            [attr.aria-pressed]="flow.priority() === p">
+            {{ p | titlecase }}
+          </button>
+        }
+      </div>
+      @if (flow.priority() === 'stat') {
+        <div class="stat-warn" role="alert">
+          <i class="ti ti-alert-triangle" aria-hidden="true"></i>
+          STAT — process immediately
+        </div>
+      }
+    </div>
+
+    <div class="op-divider" aria-hidden="true"></div>
+
+    <!-- Totals -->
+    <div class="op-section">
+      <div class="tot-row">
+        <span>Tests</span>
+        <span>{{ flow.selectedTests().length }}</span>
+      </div>
+      <div class="tot-row">
+        <span>Est. TAT</span>
+        <span>{{ flow.maxTat() }}h</span>
+      </div>
+      <div class="tot-row tot-grand" aria-label="Total amount">
+        <span>Total</span>
+        <span>₹{{ flow.orderTotal().toLocaleString('en-IN') }}</span>
+      </div>
+    </div>
+
+    <div class="op-divider" aria-hidden="true"></div>
+
+    <!-- Actions -->
+    <div class="op-actions">
