+/* ══════════════════════════════════════════════════════
+   MEDPATH LIS — Sidebar
+   ══════════════════════════════════════════════════════ */
+
+/* Background */
+.lis-sidebar { background: var(--lis-sidebar-bg, #04342C) !important; }
+
+/* ── Brand header ─────────────────────────────────── */
+.lis-brand-icon {
+  width: 34px; height: 34px;
+  background: var(--lis-primary, #1D9E75);
+  border-radius: 9px;
+  display: flex; align-items: center; justify-content: center;
+  flex-shrink: 0;
+  box-shadow: 0 2px 8px rgba(0,0,0,0.25);
+  i { color: #fff; font-size: 18px; }
+}
+
+.lis-brand-text { display: flex; flex-direction: column; gap: 1px; }
+.lis-brand-name {
+  font-size: 13px; font-weight: 600;
+  color: var(--lis-sidebar-text);
+  line-height: 1.2;
+  letter-spacing: -0.01em;
+}
+.lis-brand-sub { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 0.01em; }
+
+/* ── Section captions ─────────────────────────────── */
+.nav-caption {
+  font-size: 9.5px !important;
+  font-weight: 600 !important;
+  letter-spacing: 0.08em !important;
+  text-transform: uppercase !important;
+  color: rgba(255,255,255,0.3) !important;
+  padding: 14px 16px 4px !important;
+  margin: 0 !important;
+}
+
+/* ── Nav items ────────────────────────────────────── */
+.pc-sidebar .nav-item a {
+  border-radius: 8px !important;
+  margin: 1px 8px !important;
+  padding: 8px 10px !important;
+  gap: 9px !important;
+  font-size: 13px !important;
+  font-weight: 400 !important;
+  color: rgba(255,255,255,0.7) !important;
+  transition: background 0.12s, color 0.12s !important;
+}
+
+.pc-sidebar .nav-item a:hover {
+  background: rgba(255,255,255,0.06) !important;
+  color: rgba(255,255,255,0.92) !important;
+}
+
+.pc-sidebar .nav-item a.active {
+  background: rgba(29,158,117,0.22) !important;
+  color: #9FE1CB !important;
+  font-weight: 500 !important;
+}
+
+.pc-sidebar .nav-item a.active .nav-icon i {
+  color: var(--lis-primary, #1D9E75) !important;
+}
+
+/* ── Nav icon ─────────────────────────────────────── */
+.nav-icon {
+  width: 20px !important;
+  height: 20px !important;
+  display: flex !important;
+  align-items: center !important;
+  justify-content: center !important;
+  flex-shrink: 0 !important;
+  i { font-size: 16px !important; }
+}
+
+/* ── Badge ────────────────────────────────────────── */
+.nav-badge {
+  margin-left: auto;
+  background: #E24B4A;
+  color: #fff;
+  font-size: 10px;
+  border-radius: 10px;
+  padding: 1px 6px;
+  font-weight: 600;
+  line-height: 1.6;
+  min-width: 18px;
+  text-align: center;
+}
+
+/* ── Avatar ───────────────────────────────────────── */
+.lis-avatar {
+  width: 32px; height: 32px;
+  border-radius: 50%;
+  background: var(--lis-primary, #1D9E75);
+  display: flex; align-items: center; justify-content: center;
+  font-size: 11px; font-weight: 700; color: #fff;
+  flex-shrink: 0;
+  border: 1.5px solid rgba(255,255,255,0.15);
+}
+
+.lis-logout-icon {
+  margin-left: auto; font-size: 15px;
+  color: var(--lis-sidebar-muted);
+  cursor: pointer;
+  transition: color 0.12s;
+  &:hover { color: rgba(255,255,255,0.85); }
+}
+
+/* ── Footer ───────────────────────────────────────── */
+.sidebar-footer {
+  margin-top: auto;
+  padding: 10px 8px;
+  border-top: 1px solid var(--lis-sidebar-sep);
+}
+
+.sidebar-user {
+  display: flex; align-items: center; gap: 9px;
+  padding: 8px 10px; border-radius: 8px;
+  cursor: pointer; transition: background 0.12s;
+  &:hover { background: var(--lis-sidebar-hover); }
+}
+
+.sidebar-user-info { flex: 1; min-width: 0; }
+.sidebar-user-name {
+  font-size: 12px; font-weight: 600;
+  color: var(--lis-sidebar-text);
+  margin: 0; line-height: 1.3;
+  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
+}
+.sidebar-user-role {
+  font-size: 10px; color: var(--lis-sidebar-muted);
+  margin: 0;
+}
+
+/* ── Mobile close ─────────────────────────────────── */
+.mobile-close-btn {
+  margin-left: auto;
+  width: 32px; height: 32px;
+  border: none; border-radius: 8px;
+  background: var(--lis-sidebar-hover);
+  color: var(--lis-sidebar-muted);
+  display: flex; align-items: center; justify-content: center;
+  cursor: pointer;
+  transition: background 0.12s, color 0.12s;
+  &:hover { background: rgba(255,255,255,0.14); color: rgba(255,255,255,0.85); }
+}
