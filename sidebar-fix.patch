+/* ══════════════════════════════════════════════════════════
+   LIS SIDEBAR — Global overrides
+   Must live here (not in component CSS) because Angular
+   ViewEncapsulation scopes component styles with attribute
+   selectors, so they cannot override global .pc-sidebar rules.
+   ══════════════════════════════════════════════════════════ */
+
+/* ── Core shell — override bg-surface with brand forest green ── */
+.pc-sidebar.lis-sidebar {
+  background: var(--lis-sidebar-bg, #04342C);
+  border-right: 1px solid rgba(255,255,255,0.06);
+  box-shadow: 2px 0 16px rgba(0,0,0,0.25);
+}
+
+/* ── Brand header ───────────────────────────────────────── */
+.pc-sidebar.lis-sidebar .sidebar-brand {
+  border-bottom: 1px solid rgba(255,255,255,0.07);
+  padding: 16px 14px;
+  min-height: var(--lis-topbar-height, 56px);
+  background: rgba(0,0,0,0.12);
+}
+
+/* ── Section captions ───────────────────────────────────── */
+.pc-sidebar.lis-sidebar .nav-caption {
+  font-size: 9.5px;
+  font-weight: 700;
+  letter-spacing: 0.09em;
+  text-transform: uppercase;
+  color: rgba(255,255,255,0.28);
+  padding: 16px 14px 5px;
+}
+
+/* ── Nav links — base ───────────────────────────────────── */
+.pc-sidebar.lis-sidebar .nav-item a {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 8px 12px;
+  border-radius: 8px;
+  margin: 1px 6px;
+  color: rgba(255,255,255,0.65);
+  font-size: 13px;
+  font-weight: 400;
+  text-decoration: none;
+  transition: background 0.13s ease, color 0.13s ease;
+  white-space: nowrap;
+}
+
+/* ── Nav links — hover ──────────────────────────────────── */
+.pc-sidebar.lis-sidebar .nav-item a:hover {
+  background: rgba(255,255,255,0.07);
+  color: rgba(255,255,255,0.92);
+}
+
+/* ── Nav links — active ─────────────────────────────────── */
+.pc-sidebar.lis-sidebar .nav-item a.active {
+  background: rgba(29,158,117,0.22);
+  color: #9FE1CB;
+  font-weight: 600;
+}
+
+.pc-sidebar.lis-sidebar .nav-item a.active .nav-icon {
+  color: var(--lis-primary, #1D9E75);
+}
+
+/* ── Nav icon ───────────────────────────────────────────── */
+.pc-sidebar.lis-sidebar .nav-icon {
+  font-size: 17px;
+  width: 20px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+  color: inherit;
+}
+
+/* ── Scrollbar inside nav ───────────────────────────────── */
+.pc-sidebar.lis-sidebar .sidebar-nav::-webkit-scrollbar-track {
+  background: rgba(0,0,0,0.15);
+}
+.pc-sidebar.lis-sidebar .sidebar-nav::-webkit-scrollbar-thumb {
+  background: rgba(255,255,255,0.12);
+  border-radius: 4px;
+}
+
+/* ── Footer / user strip ────────────────────────────────── */
+.pc-sidebar.lis-sidebar .sidebar-footer {
+  border-top: 1px solid rgba(255,255,255,0.07);
+  padding: 10px 8px;
+  background: rgba(0,0,0,0.1);
+}
+
+.pc-sidebar.lis-sidebar .sidebar-user:hover {
+  background: rgba(255,255,255,0.06);
+}
+
+.pc-sidebar.lis-sidebar .sidebar-user-name {
+  color: rgba(255,255,255,0.85);
+  font-size: 12px;
+  font-weight: 600;
+}
+
+.pc-sidebar.lis-sidebar .sidebar-user-role {
+  color: rgba(255,255,255,0.42);
+  font-size: 10px;
+}
+
+/* ── Dark theme — keep sidebar dark regardless of page theme ── */
+/* Sidebar always uses its own deep forest-green palette,
+   NOT the page-level dark bg-surface (#1e293b slate).
+   Re-assert the brand bg so [data-theme="dark"] doesn't win. */
+[data-theme="dark"] .pc-sidebar.lis-sidebar {
+  background: var(--lis-sidebar-bg, #031f19);
+  border-right-color: rgba(255,255,255,0.05);
+}
+
 /* ── Shared LIS utility classes ─────────────────────────── */
 /* Used across all LIS feature components */
 
-- 
